# ============================================================================
# zeugnix.ch – Environment Variables
# ----------------------------------------------------------------------------
# Kopieren Sie diese Datei zu .env.local und füllen Sie die Werte aus.
# Auf Vercel: Settings → Environment Variables → alle hier aufgeführten setzen.
# ============================================================================

# ---- Supabase (PFLICHT) ---------------------------------------------------
# Aus Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Service Role Key (NIEMALS im Frontend / Public-Variablen verwenden)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ---- Site (PFLICHT) -------------------------------------------------------
# Auf Vercel: https://zeugnix.ch (oder zeugnix.vercel.app während Setup)
# Lokal: http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://zeugnix.ch

# ---- Resend (für Magic-Link-E-Mails der Manager-Einladungen) -------------
# Optional für MVP – im Code wird der Link aktuell zurückgegeben statt versendet
RESEND_API_KEY=re_xxx

# ---- Stripe (für Pay-per-Use von Verify und Analyse) ---------------------
# Optional für MVP – Routen sind aktuell als Stub implementiert
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
